# =============================================================================
# Resume Pipeline — Environment Variables
# Place this file at the PROJECT ROOT (same level as main.py and pyproject.toml)
#
#   resume-pipeline/
#   ├── .env                  ← HERE
#   ├── main.py
#   ├── pyproject.toml
#   ├── requirements.txt
#   └── src/
#
# NEVER commit .env to version control.
# Add ".env" to your .gitignore.
# =============================================================================


# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_LLM_TEMPERATURE=0

# ── Gemini ────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=sk-your-gemini-api-key-here
GEMINI_LLM_MODEL=gemini-2.5-flash-lite
GEMINI_LLM_TEMPERATURE=0

# ── Cohere ────────────────────────────────────────────────────────────────────
# Required when ACTIVE_RERANKER=cohere
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=sk-your-cohere-api-key-here

# ── Embedding settings ────────────────────────────────────────────────────────
OPEN_AI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=gemini-embedding-2-preview

# ── CHROMADB  (HTTP server) ───────────────────────────────────────────────────
# Hostname of the ChromaDB server.
# Local dev (no Docker): localhost
# Docker Compose: automatically overridden to "chromadb" by docker-compose.yml
CHROMA_HOST=localhost

# Port ChromaDB listens on.
# docker-compose.yml maps container :8000 → host :8001.
CHROMA_PORT=8001

# Chroma collection that stores all resume chunks.
CHROMA_COLLECTION=resumes

# Token-based auth (optional).
# Leave blank to disable — safe for local dev.
# Use a strong random string in production: openssl rand -hex 32
CHROMA_SERVER_TOKEN=

# =============================================================================
# RERANKING
# Stage 2 of the two-stage retrieval pipeline (vector search → rerank).
# Only the section matching ACTIVE_RERANKER is used at runtime.
# =============================================================================

# ── Cross-encoder reranker (local, free, default) ─────────────────────────────
# Used by: CrossEncoderReranker
# Model downloads on first run and is cached locally.
#
# Speed vs quality:
#   Fast     : cross-encoder/ms-marco-MiniLM-L-6-v2    (~67 MB)  ← default
#   Balanced : cross-encoder/ms-marco-MiniLM-L-12-v2   (~134 MB)
#   Best     : cross-encoder/ms-marco-electra-base      (~450 MB)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Options: cpu | cuda | mps
CROSS_ENCODER_DEVICE=cpu

# ── Cohere reranker (cloud, best quality) ─────────────────────────────────────
# Used by: CohereReranker  (set ACTIVE_RERANKER=cohere and swap in dependencies.py)
# Options: rerank-english-v3.0 | rerank-multilingual-v3.0 | rerank-english-v2.0
COHERE_RERANK_MODEL=rerank-english-v3.0

# ── Shared reranking config ────────────────────────────────────────────────────
# Candidates fetched from vector store before reranking.
# Recommended: 3–5× the final k.  Higher = better recall, slower reranking.
RERANK_FETCH_K=20

# ── Storage paths ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
VECTORSTORE_PATH=./resume_chroma_db


# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50


# ── Batch processing ──────────────────────────────────────────────────────────
BATCH_MAX_WORKERS=4
BATCH_MAX_FILES=50


# ── API server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true


# ── CORS (comma-separated origins, use * to allow all) ───────────────────────
CORS_ORIGINS=*


# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# MCP SERVER
# Used by mcp_server.py — only needed if running the MCP integration.
# =============================================================================

# URL of the running FastAPI backend
API_BASE_URL=http://localhost:8000

# MCP server display name (shown in Claude Desktop)
MCP_SERVER_NAME=resume-pipeline

# Log level for the MCP server process (DEBUG | INFO | WARNING | ERROR)
MCP_LOG_LEVEL=INFO

# HTTP request timeout in seconds for each API call
MCP_REQUEST_TIMEOUT=60

# Seconds between status polls when waiting for jobs to complete
MCP_POLL_INTERVAL=2

# Maximum seconds to wait before giving up on a job
MCP_POLL_MAX_WAIT=300
