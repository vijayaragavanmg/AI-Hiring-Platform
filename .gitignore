# =============================================================================
# Resume Pipeline — .gitignore
# =============================================================================


# ── Secrets ───────────────────────────────────────────────────────────────────
.env
*.pem
*.key


# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/
.env.local

# Installer logs
pip-log.txt
pip-delete-this-directory.txt


# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.test.py


# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/


# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/


# ── App data (generated at runtime) ──────────────────────────────────────────
uploads/
resume_chroma_db/
batch_report.json
*.log


# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db


# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb


# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore
docker-compose.override.yml